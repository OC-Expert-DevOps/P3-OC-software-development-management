# ─── Database ───
DATABASE_URL=postgresql://datashare:changeme@postgres:5432/datashare
POSTGRES_USER=datashare
POSTGRES_PASSWORD=changeme
POSTGRES_DB=datashare

# ─── Auth / JWT ───
JWT_SECRET=change_me_to_a_random_string_min_32_chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── MinIO (S3-compatible storage) ───
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=datashare
MINIO_USE_SSL=false

# ─── Application ───
APP_PORT=3001
APP_ENV=development
MAX_FILE_SIZE_BYTES=1073741824
FILE_EXPIRY_DAYS_DEFAULT=7
ALLOWED_ORIGINS=https://localhost
# Download links
DOWNLOAD_LINK_TTL_SECONDS=86400
